---
import BaseLayout from "../layouts/BaseLayout.astro";
import CTAButton from "../components/CTAButton.astro";
---

<BaseLayout
  title="One To One Training — TT Motorcycle School"
  description="One-to-one motorcycle training in Sussex with TT Motorcycle School. Fully personalised sessions for beginners, returning riders, and advanced learners."
>
  <section class="page-hero">
    <div class="container">
      <span class="section__eyebrow">Personalised Training</span>
      <h1 class="page-hero__title">One-to-One Intensive Licence Course</h1>
      <p class="page-hero__sub">
        A 5-day intensive course with fully dedicated instructor attention — no
        distractions, no group pressure, just focused training tailored entirely
        to you.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container content-grid">
      <div class="prose">
        <h2>Upgrade to One-to-One Tuition</h2>
        <p>
          Our 5-day intensive Motorcycle Licence Course with one-to-one tuition
          is designed to refine your riding skills and help you achieve your
          desired licence in a condensed timeframe — without distractions.
        </p>
        <p>
          This course is suitable for all abilities, with or without a valid
          CBT. It is also particularly well-suited to individuals who experience
          anxiety or social challenges in group settings, or anyone who learns
          best at their own pace with personalised attention. As the course is
          highly focused on pre-test preparation in a short space of time,
          students must have a baseline knowledge of riding techniques.
        </p>

        <h2>Training Day Structure</h2>
        <p>
          A full training day lasts approximately 5–6 hours. Beyond this, mental
          and physical fatigue can hinder progress. Start times are flexible,
          but we aim to begin between 8:00–9:00 am where possible, finishing
          between 2:00–3:00 pm.
        </p>

        <h2>Benefits of One-to-One Tuition</h2>
        <ul>
          <li>Flexibility to adapt sessions to your needs</li>
          <li>Adjustable learning pace — never rushed, never held back</li>
          <li>Uninterrupted and dedicated instructor attention</li>
          <li>Opportunity to build deeper, more refined skills</li>
          <li>Greater levels of interaction and in-depth feedback</li>
          <li>A supportive environment to overcome any barriers to learning</li>
        </ul>

        <h2>Important — Theory Test Requirement</h2>
        <p>
          This course does not include the DVSA Motorcycle Theory Test. You must
          hold a valid Theory Test certificate before attending. Please <a
            href="/contact/">contact us</a
          > if you have any questions about eligibility.
        </p>

        <div style="margin-top: var(--space-8);">
          <CTAButton
            href="/contact/"
            label="Enquire Now"
            variant="accent"
            size="md"
          />
        </div>
      </div>

      <aside class="sidebar">
        <div class="sidebar__card sidebar__card--plain">
          <h3 class="sidebar__title">Useful Links</h3>
          <ul class="sidebar__links">
            <li><a href="/bespoke-refresher/">Bespoke & Refresher</a></li>
            <li><a href="/advanced-rider/">Advanced Rider</a></li>
            <li><a href="/prices/">Pricing</a></li>
            <li><a href="/contact/">Contact Us</a></li>
          </ul>
        </div>
      </aside>
    </div>
  </section>
</BaseLayout>

<style>
  .content-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-10);
    align-items: start;
  }

  @media (min-width: 900px) {
    .content-grid {
      grid-template-columns: 1fr 280px;
    }
  }

  .sidebar__card {
    border-radius: var(--radius-lg);
    padding: var(--space-6);
  }

  .sidebar__card--plain {
    background: var(--color-bg);
    color: var(--color-text);
  }

  .sidebar__title {
    font-size: var(--text-lg);
    font-weight: 700;
    margin-bottom: var(--space-4);
  }

  .sidebar__links {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .sidebar__links a {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-accent);
    transition: color var(--transition);
  }

  .sidebar__links a:hover {
    color: var(--color-accent-hover);
  }

  .prose a {
    color: var(--color-accent);
    text-decoration: underline;
  }
</style>
