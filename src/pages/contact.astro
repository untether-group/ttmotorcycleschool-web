---
import BaseLayout from "../layouts/BaseLayout.astro";
import CTAButton from "../components/CTAButton.astro";
---

<BaseLayout
  title="Contact — TT Motorcycle School"
  description="Get in touch with TT Motorcycle School in Sussex. Ask about our courses, check availability, or book your CBT or motorcycle training."
>
  <section class="page-hero">
    <div class="container">
      <span class="section__eyebrow">Get in Touch</span>
      <h1 class="page-hero__title">Contact Us</h1>
      <p class="page-hero__sub">
        Have a question about a course, not sure which training is right for
        you, or just want to say hello? We'd love to hear from you.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container contact-grid">
      <!-- Contact details -->
      <div>
        <div class="contact-card">
          <span class="contact-card__icon" aria-hidden="true">�</span>
          <div>
            <h3 class="contact-card__title">Phone</h3>
            <p class="contact-card__body">
              Office: <a href="tel:01273041925">01273 041925</a><br />
              <span class="contact-card__note"
                >09:00 – 20:00, Monday – Saturday</span
              >
            </p>
            <p class="contact-card__body" style="margin-top: var(--space-2);">
              Mobile: <a href="tel:07592163860">07592 163860</a>
            </p>
          </div>
        </div>

        <div class="contact-card">
          <span class="contact-card__icon" aria-hidden="true">📧</span>
          <div>
            <h3 class="contact-card__title">Email</h3>
            <p class="contact-card__body">
              <a href="mailto:info@ttmotorcycleschool.com"
                >info@ttmotorcycleschool.com</a
              >
            </p>
          </div>
        </div>

        <div class="contact-card">
          <span class="contact-card__icon" aria-hidden="true">📍</span>
          <div>
            <h3 class="contact-card__title">Office Address</h3>
            <p class="contact-card__body">
              TT Motorcycle School<br />
              Pod 3, Gatehouse Hub<br />
              Neaves Park, Goddard Green<br />
              Hassocks, West Sussex<br />
              BN6 9ZN
            </p>
          </div>
        </div>

        <div class="contact-card">
          <span class="contact-card__icon" aria-hidden="true">🏍️</span>
          <div>
            <h3 class="contact-card__title">CBT Training Site</h3>
            <p class="contact-card__body">
              Stanley Deason Leisure Centre<br />
              Wilson Avenue<br />
              Brighton<br />
              BN2 5PB
            </p>
          </div>
        </div>

        <div style="margin-top: var(--space-8);">
          <CTAButton
            href="/cbtbooking/"
            label="Book Online Now"
            variant="accent"
            size="md"
          />
        </div>
      </div>

      <!-- Quick info panel -->
      <aside>
        <div class="info-panel">
          <h3 class="info-panel__title">Looking to Book?</h3>
          <p class="info-panel__body">
            The quickest way to secure your place is to book online through our
            scheduling system. Available 24/7 — choose a date and time that
            suits you.
          </p>
          <CTAButton
            href="/cbtbooking/"
            label="Go to Booking"
            variant="accent"
            size="sm"
          />
        </div>

        <div
          class="info-panel info-panel--plain"
          style="margin-top: var(--space-5);"
        >
          <h3 class="info-panel__title">Useful Links</h3>
          <ul class="info-panel__links">
            <li><a href="/cbt/">About CBT</a></li>
            <li><a href="/full-licence/">Full Licence</a></li>
            <li><a href="/prices/">Prices</a></li>
            <li><a href="/new-rider/">New to Riding</a></li>
          </ul>
        </div>
      </aside>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-12);
    align-items: start;
  }

  @media (min-width: 900px) {
    .contact-grid {
      grid-template-columns: 1fr 300px;
    }
  }

  .contact-card {
    display: flex;
    gap: var(--space-4);
    align-items: flex-start;
    padding-block: var(--space-5);
    border-bottom: 1px solid var(--color-border);
  }

  .contact-card:first-child {
    padding-top: 0;
  }

  .contact-card__icon {
    font-size: 1.5rem;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .contact-card__title {
    font-size: var(--text-sm);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-muted);
    margin-bottom: var(--space-1);
  }

  .contact-card__body {
    font-size: var(--text-base);
    color: var(--color-text);
    line-height: var(--leading-normal);
  }

  .contact-card__body a {
    color: var(--color-accent);
    text-decoration: underline;
  }

  .contact-card__note {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .info-panel {
    background: var(--color-primary);
    color: var(--color-white);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
  }

  .info-panel--plain {
    background: var(--color-bg);
    color: var(--color-text);
  }

  .info-panel__title {
    font-size: var(--text-lg);
    font-weight: 700;
    margin-bottom: var(--space-3);
  }

  .info-panel__body {
    font-size: var(--text-sm);
    color: #ccc;
    line-height: var(--leading-normal);
    margin-bottom: var(--space-5);
  }

  .info-panel__links {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .info-panel__links a {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-accent);
    transition: color var(--transition);
  }

  .info-panel__links a:hover {
    color: var(--color-accent-hover);
  }
</style>
