---
import BaseLayout from "../layouts/BaseLayout.astro";
import CTAButton from "../components/CTAButton.astro";
---

<BaseLayout
  title="Google Reviews — TT Motorcycle School"
  description="Read Google reviews for TT Motorcycle School in Sussex. See why riders across the region choose TT for their CBT, full licence, and advanced training."
>
  <section class="page-hero">
    <div class="container">
      <span class="section__eyebrow">Google Reviews</span>
      <h1 class="page-hero__title">Our Google Reviews</h1>
      <p class="page-hero__sub">
        See what riders are saying about TT Motorcycle School on Google. We're
        proud of our five-star rating and the feedback from our students means
        the world to us.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="reviews-badge">
        <div class="reviews-badge__stars" aria-label="5 star rating">★★★★★</div>
        <div class="reviews-badge__label">Rated 5 Stars on Google</div>
        <p class="reviews-badge__sub">
          Based on reviews from verified Google users
        </p>
      </div>

      <!-- Google Reviews widget / embed goes here -->
      <!-- Elfsight Google Reviews | Untitled Google Reviews -->
      <script src="https://elfsightcdn.com/platform.js" async></script>
      <div
        class="elfsight-app-627f8188-6b5b-4392-81c2-e6f0267f861e"
        data-elfsight-app-lazy
      >
      </div>

      <div class="reviews-cta">
        <CTAButton
          href="/testimonials/"
          label="Read Written Testimonials"
          variant="primary"
          size="md"
        />
        &nbsp;&nbsp;
        <CTAButton
          href="/cbtbooking/"
          label="Book Your Training"
          variant="accent"
          size="md"
        />
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .reviews-badge {
    text-align: center;
    margin-bottom: var(--space-10);
  }

  .reviews-badge__stars {
    font-size: 3rem;
    color: #f59e0b;
    letter-spacing: 4px;
    margin-bottom: var(--space-3);
  }

  .reviews-badge__label {
    font-size: var(--text-2xl);
    font-weight: 800;
    margin-bottom: var(--space-2);
  }

  .reviews-badge__sub {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .reviews-embed-placeholder {
    background: var(--color-bg);
    border: 2px dashed var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-12) var(--space-8);
    text-align: center;
    margin-bottom: var(--space-10);
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    line-height: var(--leading-normal);
  }

  .reviews-embed-placeholder__link {
    display: inline-block;
    margin-top: var(--space-4);
    font-weight: 700;
    color: var(--color-accent);
    text-decoration: underline;
  }

  .reviews-cta {
    text-align: center;
  }
</style>
