---
import BaseLayout from "../layouts/BaseLayout.astro";

const required = [
  {
    item: "Helmet",
    detail:
      "Must meet British safety standards. Accepted standards: BS 6658:1985 with BSI Kitemark; UNECE Regulation 22.05 or 22.06; or an EEA equivalent offering at least the same protection and carrying an equivalent mark. If you have your own, bring it — otherwise one will be provided.",
    required: true,
  },
  {
    item: "Gloves",
    detail:
      "Must be motorbike appropriate. Provided if you do not have your own.",
    required: true,
  },
  {
    item: "Jacket",
    detail:
      "Must be motorbike appropriate. Provided if you do not have your own.",
    required: true,
  },
  {
    item: "Trousers",
    detail:
      "Minimum of thick jeans with no rips. Motorcycle jeans or leather/textile over-trousers are better. Waterproof trousers provided if needed.",
    required: true,
  },
  {
    item: "Boots",
    detail:
      "Motorcycle boots or sturdy ankle-covering boots (e.g. DMs or hiking boots). No steel toe-cap boots, trainers, canvas shoes, or high heels.",
    required: true,
  },
  {
    item: "Hi-Vis Vest",
    detail:
      "Provided as part of the course. You are welcome to bring your own.",
    required: true,
  },
];
---

<BaseLayout
  title="What to Wear — TT Motorcycle School"
  description="Find out exactly what to wear for your CBT or motorcycle training at TT Motorcycle School in Sussex. Clothing requirements, recommended kit, and safety guidance."
>
  <section class="page-hero">
    <div class="container">
      <span class="section__eyebrow">Preparing for Training</span>
      <h1 class="page-hero__title">What to Wear</h1>
      <p class="page-hero__sub">
        Wearing the right gear is essential for your safety on a motorcycle.
        Here's exactly what you need to bring to your training with TT
        Motorcycle School.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container content-two-col">
      <div>
        <div class="prose">
          <p>
            When considering booking any training course with TT Motorcycle
            School, you will need to adhere to our clothing requirements. <strong
              >Anyone who arrives in less than the minimum required clothing
              will unfortunately be turned away without a refund.</strong
            >
            Your safety is paramount to us, which is why these requirements must be
            met.
          </p>
          <p>
            The following equipment and safety clothing is <strong
              >included in the price</strong
            >
            of every course: helmet, gloves, jacket, hi-vis vest, and waterproof trousers
            (if needed). If you have your own, feel free to bring it — but it must
            meet the requirements below.
          </p>
        </div>

        <h2 class="wear-section-title">Required Kit</h2>
        <div class="wear-list">
          {
            required.map((item) => (
              <div class="wear-item">
                <div class="wear-item__header">
                  <span class="wear-item__name">{item.item}</span>
                  <span class="wear-item__badge">Required</span>
                </div>
                <p class="wear-item__detail">{item.detail}</p>
              </div>
            ))
          }
        </div>

        <div class="prose" style="margin-top: var(--space-8);">
          <h2>Questions?</h2>
          <p>
            Not sure if your gear meets the requirements? <a href="/contact/"
              >Contact us</a
            > before your course and we'll be happy to advise.
          </p>
        </div>
      </div>

      <aside class="sidebar">
        <div class="sidebar__card sidebar__card--accent">
          <h3 class="sidebar__title">Clothing Checklist</h3>
          <ul class="sidebar__checklist">
            <li>☑ Helmet (BS 6658:1985 / UNECE 22.05/06)</li>
            <li>☑ Motorbike-appropriate gloves</li>
            <li>☑ Motorbike-appropriate jacket</li>
            <li>☑ Thick jeans (no rips) or better</li>
            <li>☑ Ankle-covering boots (no steel toe caps)</li>
          </ul>
        </div>
        <div
          class="sidebar__card sidebar__card--plain"
          style="margin-top: var(--space-5);"
        >
          <h3 class="sidebar__title">Useful Links</h3>
          <ul class="sidebar__links">
            <li><a href="/cbt/">About CBT</a></li>
            <li><a href="/new-rider/">New to Riding</a></li>
            <li><a href="/contact/">Contact Us</a></li>
          </ul>
        </div>
      </aside>
    </div>
  </section>
</BaseLayout>

<style>
  .content-two-col {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-10);
    align-items: start;
  }

  @media (min-width: 900px) {
    .content-two-col {
      grid-template-columns: 1fr 280px;
    }
  }

  .wear-section-title {
    font-size: var(--text-2xl);
    font-weight: 700;
    margin-top: var(--space-10);
    margin-bottom: var(--space-6);
  }

  .wear-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .wear-item {
    background: var(--color-bg);
    border-radius: var(--radius-md);
    padding: var(--space-5);
  }

  .wear-item__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-2);
  }

  .wear-item__name {
    font-weight: 700;
    font-size: var(--text-base);
  }

  .wear-item__badge {
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    background: var(--color-accent);
    color: #fff;
    padding: 2px 8px;
    border-radius: 999px;
  }

  .wear-item__detail {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: var(--leading-normal);
  }

  .recommended-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    margin-top: var(--space-4);
  }

  .recommended-list li {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    padding-left: var(--space-5);
    position: relative;
  }

  .recommended-list li::before {
    content: "→";
    position: absolute;
    left: 0;
    color: var(--color-accent);
    font-weight: 700;
  }

  .sidebar__card {
    border-radius: var(--radius-lg);
    padding: var(--space-6);
  }

  .sidebar__card--accent {
    background: var(--color-primary);
    color: var(--color-white);
  }

  .sidebar__card--plain {
    background: var(--color-bg);
  }

  .sidebar__title {
    font-size: var(--text-lg);
    font-weight: 700;
    margin-bottom: var(--space-4);
  }

  .sidebar__checklist {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    font-size: var(--text-sm);
    color: #ccc;
  }

  .sidebar__links {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .sidebar__links a {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-accent);
    transition: color var(--transition);
  }

  .sidebar__links a:hover {
    color: var(--color-accent-hover);
  }

  .prose a {
    color: var(--color-accent);
    text-decoration: underline;
  }
</style>
