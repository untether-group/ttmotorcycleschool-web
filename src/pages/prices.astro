---
import BaseLayout from "../layouts/BaseLayout.astro";
import CTAButton from "../components/CTAButton.astro";
---

<BaseLayout
  title="Prices — TT Motorcycle School"
  description="Transparent pricing for motorcycle training at TT Motorcycle School in Sussex. CBT, full licence, one-to-one and refresher courses. All prices include bike, equipment and test fees."
>
  <section class="page-hero">
    <div class="container">
      <span class="section__eyebrow">Transparent Pricing</span>
      <h1 class="page-hero__title">Prices</h1>
      <p class="page-hero__sub">
        No hidden fees. No surprises. All course prices include the use of a
        training bike, equipment and practical test fees where applicable.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container prices-layout">
      <div class="prices-content">
        <!-- New Rider -->
        <div class="price-section">
          <h2 class="price-section__title">New Rider</h2>
          <p class="price-section__desc">
            One hour on the bike with one-to-one tuition in a safe, private
            off-road environment.
          </p>
          <ul class="price-list">
            <li>
              <span class="price-list__item">One person</span><span
                class="price-list__amount">£40</span
              >
            </li>
            <li>
              <span class="price-list__item">Two people booked together</span
              ><span class="price-list__amount">£70</span>
            </li>
          </ul>
        </div>

        <!-- Gearing Up for Gears -->
        <div class="price-section">
          <h2 class="price-section__title">Gearing Up for Gears</h2>
          <p class="price-section__desc">
            An introductory session covering clutch control and gear changes for
            riders new to manual bikes.
          </p>
          <ul class="price-list">
            <li>
              <span class="price-list__item">One hour session</span><span
                class="price-list__amount">£40</span
              >
            </li>
          </ul>
        </div>

        <!-- CBT -->
        <div class="price-section">
          <h2 class="price-section__title">Compulsory Basic Training (CBT)</h2>
          <p class="price-section__desc">
            A full-day training course with a maximum of two riders per
            instructor. Includes bike hire, insurance, equipment and petrol.
          </p>
          <ul class="price-list">
            <li>
              <span class="price-list__item"
                >Standard CBT (bike, equipment &amp; insurance included)</span
              ><span class="price-list__amount">£195</span>
            </li>
            <li>
              <span class="price-list__item"
                >CBT Renewal — using your own bike</span
              ><span class="price-list__amount">£150</span>
            </li>
            <li>
              <span class="price-list__item">CBT Retest (full day)</span><span
                class="price-list__amount">£120</span
              >
            </li>
            <li>
              <span class="price-list__item"
                >2-hour road ride (if not successful first time)</span
              ><span class="price-list__amount">£60</span>
            </li>
            <li>
              <span class="price-list__item"
                >1:1 CBT — bike hire, insurance, equipment &amp; petrol included</span
              ><span class="price-list__amount">£250</span>
            </li>
          </ul>
        </div>

        <!-- Full Licence -->
        <div class="price-section">
          <h2 class="price-section__title">
            Full Licence — A1, A2 &amp; Direct Access (DAS)
          </h2>
          <p class="price-section__desc">
            Available for A1 (17+), A2 (19+) and full A licence (24+). Module 1
            &amp; 2 tests are taken on the final day, or split between the last
            two days. All packages include bike, equipment and test fees.
          </p>
          <ul class="price-list price-list--cards">
            <li class="price-list__card">
              <strong class="price-list__card-title"
                >Three-Day Course — £770</strong
              >
              <p>
                Ideal for the experienced rider looking to upgrade their licence
                — for example from A2 to full A. Module 1 &amp; 2 tests on the
                final day.
              </p>
            </li>
            <li class="price-list__card price-list__card--featured">
              <strong class="price-list__card-title"
                >Four-Day Course — £870</strong
              >
              <p>
                Our most popular course. Suited to riders who have completed
                their CBT and feel comfortable on a bike. Module 1 &amp; 2 tests
                on the final day.
              </p>
              <span class="price-list__card-badge">Most Popular</span>
            </li>
            <li class="price-list__card">
              <strong class="price-list__card-title"
                >Five-Day Course — £970</strong
              >
              <p>
                Designed for those new to biking who want to feel fully safe and
                confident before testing. Module 1 &amp; 2 tests on the final
                day.
              </p>
            </li>
          </ul>
        </div>
      </div>

      <!-- Other -->
      <div class="price-section">
        <h2 class="price-section__title">Additional Training</h2>
        <ul class="price-list">
          <li>
            <span class="price-list__item"
              >Hourly training (not part of a course)</span
            ><span class="price-list__amount">£50/hr</span>
          </li>
          <li>
            <span class="price-list__item"
              >Full day training — 5 hours (not part of a course)</span
            ><span class="price-list__amount">£250</span>
          </li>
          <li>
            <span class="price-list__item"
              >Recap session + accompanied test</span
            ><span class="price-list__amount">From £100 + test fee</span>
          </li>
        </ul>
      </div>

      <!-- Refresher -->
      <div class="price-section">
        <h2 class="price-section__title">Refresher Course</h2>
        <p class="price-section__desc">
          Returning to riding after a break? Our refresher course gets your
          confidence and skills back up to scratch.
        </p>
        <ul class="price-list">
          <li>
            <span class="price-list__item"
              >All inclusive — bike hire, insurance, equipment &amp; fuel</span
            ><span class="price-list__amount">£220</span>
          </li>
        </ul>
      </div>

      <div class="price-section">
        <h2 class="price-section__title">Bespoke Lesson</h2>
        <p class="price-section__desc">
          Flexible one-to-one training tailored to the specific skills you want
          to work on.
        </p>
        <ul class="price-list">
          <li>
            <span class="price-list__item"
              >Hourly rate for bespoke lessons:</span
            >
          </li>
          <li>
            <span class="price-list__item">CBT</span><span
              class="price-list__amount">£60/hr</span
            >
          </li>
          <li>
            <span class="price-list__item">DAS (big bike)</span><span
              class="price-list__amount">£90/hr</span
            >
          </li>
        </ul>
      </div>

      <!-- Test Fees -->
      <div class="price-section price-section--note">
        <h2 class="price-section__title">DVSA Test Fees</h2>
        <p class="price-section__desc">
          Test fees are set by the DVSA and are <strong
            >included in all our package prices above</strong
          >. Listed here for reference.
        </p>
        <ul class="price-list">
          <li>
            <span class="price-list__item">Module 1</span><span
              class="price-list__amount">£15.50</span
            >
          </li>
          <li>
            <span class="price-list__item">Module 2</span><span
              class="price-list__amount">£75.00</span
            >
          </li>
        </ul>
      </div>

      <div class="prose prices-footer">
        <h2>Questions?</h2>
        <p>
          If you're unsure which course is right for you, <a href="/contact/"
            >get in touch</a
          > — we're always happy to help.
        </p>
        <h2>Cancellation Policy</h2>
        <p>
          Please see our <a href="/terms-and-conditions/"
            >Terms and Conditions</a
          > for our full cancellation and rescheduling policy.
        </p>
      </div>
    </div>

    <aside class="prices-sidebar">
      <div class="sidebar__card">
        <h3 class="sidebar__title">Ready to Book?</h3>
        <p class="sidebar__body">
          Spaces fill up quickly. Secure your training today.
        </p>
        <CTAButton
          href="/cbtbooking/"
          label="Book Online"
          variant="accent"
          size="md"
        />
      </div>
      <div class="sidebar__card sidebar__card--plain">
        <h3 class="sidebar__title">Useful Links</h3>
        <ul class="sidebar__links">
          <li><a href="/cbt/">About CBT</a></li>
          <li><a href="/new-rider/">New Rider Course</a></li>
          <li><a href="/full-licence/">Full Licence</a></li>
          <li><a href="/bespoke-refresher/">Refresher Training</a></li>
          <li><a href="/contact/">Contact Us</a></li>
        </ul>
      </div>
    </aside>
  </section>
</BaseLayout>

<style>
  .prices-layout {
    display: grid;
    gap: var(--space-10);
    align-items: start;
  }

  @media (min-width: 900px) {
    .prices-layout {
      grid-template-columns: 1fr 280px;
    }
  }

  .prices-content {
    display: flex;
    flex-direction: column;
    gap: var(--space-10);
  }

  /* Section blocks */
  .price-section {
    border-bottom: 1px solid var(--color-border);
    padding-bottom: var(--space-10);
  }

  .price-section:last-of-type {
    border-bottom: none;
  }

  .price-section--note {
    background: var(--color-bg);
    border: none;
    border-left: 4px solid var(--color-accent);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    padding: var(--space-6);
    padding-bottom: var(--space-6);
  }

  .price-section__title {
    font-size: var(--text-2xl);
    font-weight: 800;
    margin-bottom: var(--space-2);
    color: var(--color-text);
  }

  .price-section__desc {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    margin-bottom: var(--space-5);
    line-height: var(--leading-normal);
  }

  /* Price rows */
  .price-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .price-list > li {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--space-4);
    padding: var(--space-3) 0;
    border-bottom: 1px solid var(--color-border);
    font-size: var(--text-base);
  }

  .price-list > li:last-child {
    border-bottom: none;
  }

  .price-list__item {
    color: var(--color-text);
  }

  .price-list__amount {
    font-weight: 800;
    color: var(--color-accent);
    white-space: nowrap;
    font-size: var(--text-lg);
  }

  /* Licence course cards */
  .price-list--cards {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
  }

  @media (min-width: 640px) {
    .price-list--cards {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .price-list--cards > li {
    display: block;
    border: 2px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
    border-bottom: 2px solid var(--color-border);
  }

  .price-list__card--featured {
    border-color: var(--color-accent);
    position: relative;
  }

  .price-list__card-badge {
    display: inline-block;
    background: var(--color-accent);
    color: #fff;
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 2px 10px;
    border-radius: 999px;
    margin-top: var(--space-5);
  }

  .price-list__card-title {
    display: block;
    font-size: var(--text-lg);
    font-weight: 800;
    color: var(--color-accent);
    margin-bottom: var(--space-3);
  }

  .price-list__card p {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: var(--leading-normal);
  }

  /* Sidebar */
  .prices-sidebar {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .sidebar__card {
    background: var(--color-primary);
    color: var(--color-white);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
  }

  .sidebar__card--plain {
    background: var(--color-bg);
    color: var(--color-text);
  }

  .sidebar__title {
    font-size: var(--text-lg);
    font-weight: 700;
    margin-bottom: var(--space-3);
  }

  .sidebar__body {
    font-size: var(--text-sm);
    color: #ccc;
    margin-bottom: var(--space-4);
    line-height: var(--leading-normal);
  }

  .sidebar__links {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .sidebar__links a {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-accent);
    text-decoration: underline;
  }

  .sidebar__links a:hover {
    color: var(--color-accent-hover);
  }

  /* Footer prose */
  .prices-footer {
    max-width: 640px;
  }

  .prose a {
    color: var(--color-accent);
    text-decoration: underline;
  }

  .prose h2 {
    font-size: var(--text-xl);
    font-weight: 700;
    margin-top: var(--space-8);
    margin-bottom: var(--space-3);
  }

  .prose p {
    color: var(--color-text-muted);
    line-height: var(--leading-normal);
  }
</style>
