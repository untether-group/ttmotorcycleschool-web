---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTAButton from '../components/CTAButton.astro';

const prices = [
  {
    label: 'CBT',
    amount: 'POA',
    desc: 'Compulsory Basic Training — full day course',
    features: [
      'Full day (approx. 6–8 hrs)',
      'Training motorcycle provided',
      'DL196 certificate on completion',
      'Valid for 2 years',
    ],
    featured: true,
    cta: '/cbtbooking/',
  },
  {
    label: 'Full Licence Training',
    amount: 'POA',
    desc: 'Structured lessons for A1, A2 or full A category',
    features: [
      'Module 1 preparation',
      'Module 2 preparation',
      'Flexible lesson packages',
      'Mock test included',
    ],
    featured: false,
    cta: '/cbtbooking/',
  },
  {
    label: 'One-to-One Session',
    amount: 'POA',
    desc: 'Personalised training tailored to you',
    features: [
      'Your choice of focus area',
      'Fully flexible duration',
      'Advanced or refresher focus',
      'Instructor feedback report',
    ],
    featured: false,
    cta: '/cbtbooking/',
  },
];
---

<BaseLayout
  title="Prices — TT Motorcycle School"
  description="Transparent pricing for motorcycle training at TT Motorcycle School in Sussex. CBT, full licence, one-to-one and refresher courses."
>
  <section class="page-hero">
    <div class="container">
      <span class="section__eyebrow">Transparent Pricing</span>
      <h1 class="page-hero__title">Prices</h1>
      <p class="page-hero__sub">
        No hidden fees. No surprises. Just straightforward, competitive pricing for
        professional motorcycle training in Sussex.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="prices-note">
        <p>
          Prices are updated regularly. Please contact us or book online for the most current rates.
          All prices include the use of a training motorcycle and full instructor time.
        </p>
      </div>

      <div class="grid-3 prices-grid">
        {prices.map(p => (
          <div class:list={['price-card', { 'price-card--featured': p.featured }]}>
            {p.featured && <span class="price-card__badge">Most Popular</span>}
            <div class="price-card__amount">{p.amount}</div>
            <div class="price-card__label">{p.label}</div>
            <p class="price-card__desc">{p.desc}</p>
            <ul class="price-card__features">
              {p.features.map(f => <li>{f}</li>)}
            </ul>
            <CTAButton href={p.cta} label="Book Now" variant={p.featured ? 'accent' : 'primary'} size="md" />
          </div>
        ))}
      </div>

      <div class="prose prices-footer">
        <h2>What's Included?</h2>
        <p>
          All sessions include the use of a training motorcycle (if required), full instructor time,
          and use of our training facilities. There are no add-on fees for equipment or certificates.
        </p>
        <h2>Cancellation Policy</h2>
        <p>
          We understand that plans can change. Please see our <a href="/terms-and-conditions/">Terms and Conditions</a>
          for our full cancellation and rescheduling policy.
        </p>
        <h2>Questions?</h2>
        <p>
          If you're unsure which course is right for you, <a href="/contact/">get in touch</a> — we're always happy to help.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .prices-note {
    background: var(--color-bg);
    border-left: 4px solid var(--color-accent);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    padding: var(--space-5) var(--space-6);
    margin-bottom: var(--space-10);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .prices-grid {
    margin-bottom: var(--space-16);
  }

  .price-card__badge {
    display: inline-block;
    background: var(--color-accent);
    color: var(--color-white);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 2px 10px;
    border-radius: 999px;
    margin-bottom: var(--space-4);
  }

  .prices-footer {
    max-width: 640px;
  }

  .prose a {
    color: var(--color-accent);
    text-decoration: underline;
  }
</style>
