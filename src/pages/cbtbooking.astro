---
import BaseLayout from '../layouts/BaseLayout.astro';
import AcuityWidget from '../components/AcuityWidget.astro';
---

<BaseLayout
  title="CBT Booking — TT Motorcycle School"
  description="Book your CBT or motorcycle training course with TT Motorcycle School in Sussex. Select a date and time that suits you."
>
  <section class="page-hero">
    <div class="container">
      <span class="section__eyebrow">Online Booking</span>
      <h1 class="page-hero__title">Book Your Training</h1>
      <p class="page-hero__sub">
        Choose a course, pick a date that suits you, and secure your place in minutes.
        All bookings are managed through our secure online scheduler.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <AcuityWidget />
      <p class="booking-note">
        Can't find a suitable slot? <a href="/contact/">Contact us</a> and we'll do our best to accommodate you.
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .booking-note {
    margin-top: var(--space-6);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    text-align: center;
  }

  .booking-note a {
    color: var(--color-accent);
    text-decoration: underline;
  }
</style>
