---
import BaseLayout from "../layouts/BaseLayout.astro";
import CTAButton from "../components/CTAButton.astro";

const testimonials = [
  {
    quote:
      "Alan is the best instructor out there. Before doing my week's training I'd only ridden my 125cc occasionally due to having a car. I was very nervous about riding a bigger engined bike, but Alan is extremely patient, knowledgeable and wants you to pass.",
    author: "Courtney S.",
    course: "Full Licence",
  },
  {
    quote:
      "Al was a wonderful teacher, felt like a comfortable rider by the end of everything. Makes you feel confident. Could not recommend TT enough! Worth the trip down from London.",
    author: "Blair H.",
    course: "Full Licence",
  },
  {
    quote:
      "Really enjoyed my time learning from Alan — he is a really nice guy. I did my CBT with him, practised my Mod 1 with him and practised my Mod 2 with him and passed both. Would highly recommend and will definitely be sending my 17-year-old son on his CBT with him.",
    author: "Alan H.",
    course: "CBT & Full Licence",
  },
  {
    quote:
      "Alan and his team successfully trained myself and my best mate to both pass our full DAS first time, maintaining their 90% pass rate. I would recommend TT Motorcycle School without hesitation!",
    author: "Simon M.",
    course: "Direct Access",
  },
  {
    quote:
      "Thoroughly recommend TT for their service. Passed 1st time doing accelerated course. Thank you Alan for the training, and thanks to Sammi for efficient communication and booking.",
    author: "Zak G.",
    course: "Full Licence",
  },
  {
    quote:
      "Had such good fun and really appreciated the great instruction and advice from the team at TT Motorcycle School. Completed my CBT today and will definitely be heading back for DAS. I can't recommend highly enough, thanks guys! :)",
    author: "Richard C.",
    course: "CBT",
  },
];
---

<BaseLayout
  title="Testimonials — TT Motorcycle School"
  description="Read reviews and testimonials from TT Motorcycle School students in Sussex. See what our riders have to say about their CBT, full licence, and advanced training."
>
  <section class="page-hero">
    <div class="container">
      <span class="section__eyebrow">Student Reviews</span>
      <h1 class="page-hero__title">What Our Students Say</h1>
      <p class="page-hero__sub">
        Don't just take our word for it — here's what riders from across Sussex
        and the surrounding area have said about training with TT Motorcycle
        School.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="grid-3 testimonials-grid">
        {
          testimonials.map((t) => (
            <div class="testimonial-card">
              <div class="stars" aria-label="5 stars">
                ★★★★★
              </div>
              <p class="testimonial-card__quote">"{t.quote}"</p>
              <div class="testimonial-card__footer">
                <span class="testimonial-card__author">— {t.author}</span>
                <span class="testimonial-card__course">{t.course}</span>
              </div>
            </div>
          ))
        }
      </div>

      <div class="testimonials-cta">
        <p class="testimonials-cta__text">
          See even more reviews on our
          <a href="/google-reviews/">Google Reviews page</a>.
        </p>
        <CTAButton
          href="/cbtbooking/"
          label="Book Your Training"
          variant="accent"
          size="md"
        />
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .testimonials-grid {
    margin-bottom: var(--space-12);
  }

  .testimonial-card {
    background: var(--color-bg);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
    border-left: 4px solid var(--color-accent);
    display: flex;
    flex-direction: column;
  }

  .testimonial-card__quote {
    font-size: var(--text-base);
    font-style: italic;
    line-height: var(--leading-normal);
    color: var(--color-text-muted);
    flex: 1;
    margin-block: var(--space-3);
  }

  .testimonial-card__footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-top: var(--space-4);
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-border);
  }

  .testimonial-card__author {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text);
  }

  .testimonial-card__course {
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent);
    background: rgba(230, 51, 41, 0.08);
    padding: 2px 8px;
    border-radius: 999px;
  }

  .testimonials-cta {
    text-align: center;
    padding-top: var(--space-8);
    border-top: 1px solid var(--color-border);
  }

  .testimonials-cta__text {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    margin-bottom: var(--space-6);
  }

  .testimonials-cta__text a {
    color: var(--color-accent);
    text-decoration: underline;
    font-weight: 600;
  }
</style>
