---
import CTAButton from "./CTAButton.astro";
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<section class="hero" aria-label="Welcome to TT Motorcycle School">
  <div class="hero__bg-image" style={`background-image: url('${base}/images/hero-image.png')`}></div>
  <div class="hero__bg-overlay"></div>
  <img
    src={`${base}/images/hero-image.png`}
    alt="Motorcycle training"
    class="hero__img-mobile"
  />
  <div class="container hero__content hero__content-bg">
    <span class="hero__eyebrow">CBT · Full Licence · Advanced Riding</span>
    <h1 class="hero__title">
      Get on the Road.<br />
      <span class="hero__title-accent">Ride with Confidence.</span>
    </h1>
    <p class="hero__sub">
      Professional motorcycle training in Sussex. Whether you're a complete
      beginner or returning to riding, TT Motorcycle School has a course for
      you.
    </p>
    <div class="hero__actions">
      <CTAButton
        href="/cbtbooking/"
        label="Book Your Training"
        variant="accent"
        size="lg"
      />
      <CTAButton
        href="/new-rider/"
        label="New to riding?"
        variant="outline"
        size="lg"
      />
    </div>
    <div class="hero__trust">
      <div class="hero__trust-item">
        <span class="hero__trust-value">5★</span>
        <span class="hero__trust-label">Google Rated</span>
      </div>
      <div class="hero__trust-divider"></div>
      <div class="hero__trust-item">
        <span class="hero__trust-value">DVSA</span>
        <span class="hero__trust-label">Approved Instructor</span>
      </div>
      <div class="hero__trust-divider"></div>
      <div class="hero__trust-item">
        <span class="hero__trust-value">Sussex</span>
        <span class="hero__trust-label">&amp; Surrounding Counties</span>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    background-color: var(--color-primary);
    color: var(--color-white);
    padding-block: var(--space-24);
    overflow: hidden;
  }

  /* Subtle diagonal accent stripe */
  .hero__bg-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      rgba(230, 51, 41, 0.12) 0%,
      transparent 60%
    );
    pointer-events: none;
  }

  .hero__content {
    position: relative;
    z-index: 1;
    max-width: 700px;
  }

  .hero__eyebrow {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: var(--space-4);
  }

  .hero__title {
    font-size: var(--text-5xl);
    font-weight: 800;
    line-height: var(--leading-tight);
    margin-bottom: var(--space-6);
  }

  @media (min-width: 768px) {
    .hero__title {
      font-size: var(--text-6xl);
    }
  }

  .hero__title-accent {
    color: var(--color-accent);
  }

  .hero__sub {
    font-size: var(--text-lg);
    color: #ccc;
    line-height: var(--leading-normal);
    margin-bottom: var(--space-8);
    max-width: 580px;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    margin-bottom: var(--space-12);
  }

  /* Trust bar */
  .hero__trust {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-4);
  }

  .hero__trust-item {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .hero__trust-value {
    font-size: var(--text-base);
    font-weight: 800;
    color: var(--color-white);
    letter-spacing: 0.02em;
  }

  .hero__trust-label {
    font-size: var(--text-xs);
    color: #888;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .hero__trust-divider {
    width: 1px;
    height: 32px;
    background-color: rgba(255, 255, 255, 0.15);
  }
  .hero__content-bg {
    background: rgba(17, 17, 17, 0.82);
    border-radius: var(--radius-lg);
    box-shadow: 0 4px 32px 0 rgba(0, 0, 0, 0.18);
    padding: var(--space-8) var(--space-6);
    max-width: 700px;
    margin-inline: auto;
    backdrop-filter: blur(2px);
  }
  .hero__bg-image {
    display: none;
  }
  .hero__img-mobile {
    display: block;
    width: 100%;
    height: auto;
    max-height: 220px;
    object-fit: cover;
    margin-bottom: var(--space-6);
    border-radius: var(--radius-lg);
  }
  @media (min-width: 768px) {
    .hero__bg-image {
      display: block;
      position: absolute;
      inset: 0;
      z-index: 0;
      background-size: cover;
      background-position: center center;
      background-repeat: no-repeat;
      width: 100%;
      height: 100%;
      opacity: 0.55;
      pointer-events: none;
      transition: opacity 0.3s;
    }
    .hero__img-mobile {
      display: none;
    }
  }
</style>
