---
// Acuity Scheduling embed widget
// Replace the src URL with your own Acuity scheduling link.
// Find it in: Acuity → Business Settings → Scheduling Page Link
const acuityURL =
  "https://app.acuityscheduling.com/schedule/f54dee23?ref=embedded_csp";
---

<div class="acuity-widget">
  <iframe
    src={acuityURL}
    title="Schedule Appointment"
    width="100%"
    height="800"
    allow="payment"
    class="acuity-widget__iframe"></iframe>
  <script
    src="https://embed.acuityscheduling.com/js/embed.js"
    type="text/javascript"></script>
</div>

<style>
  .acuity-widget {
    width: 100%;
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-md);
  }

  .acuity-widget__iframe {
    display: block;
    min-height: 800px;
    width: 100%;
    border: none;
  }
</style>
