---
const courses = [
  { label: "New Rider", href: "/new-rider/" },
  { label: "CBT", href: "/cbt/" },
  { label: "Full Licence", href: "/full-licence/" },
  { label: "Advanced Rider", href: "/advanced-rider/" },
  { label: "One-to-One", href: "/OneToOneTraining/" },
  { label: "Bespoke & Refresher", href: "/bespoke-refresher/" },
  { label: "E-bikes", href: "/e-bikes/" },
  { label: "Prices", href: "/prices/" },
];

const info = [
  { label: "About", href: "/about/" },
  { label: "What to Wear", href: "/what-to-wear/" },
  { label: "Learning Resources", href: "/learning-resources/" },
  { label: "Testimonials", href: "/testimonials/" },
  { label: "Google Reviews", href: "/google-reviews/" },
  { label: "Contact", href: "/contact/" },
];

const legal = [{ label: "Terms & Conditions", href: "/terms-and-conditions/" }];
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const url = (path: string) => `${base}${path}`;
---

<footer class="footer">
  <div class="container footer__grid">
    <!-- Brand -->
    <div class="footer__brand">
      <a href={url("/")} aria-label="TT Motorcycle School — Home">
        <img
          src={url("/logo.svg")}
          alt="TT Motorcycle School"
          width="140"
          height="42"
        />
      </a>
      <p class="footer__tagline">
        Professional motorcycle training in Sussex and the surrounding counties.
        Get on the road with confidence.
      </p>
      <a href={url("/cbtbooking/")} class="footer__cta">Book Your Training →</a>
    </div>

    <!-- Courses -->
    <div class="footer__col">
      <h3 class="footer__col-title">Courses</h3>
      <ul class="footer__links">
        {
          courses.map((link) => (
            <li>
              <a href={url(link.href)} class="footer__link">
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <!-- Info -->
    <div class="footer__col">
      <h3 class="footer__col-title">Information</h3>
      <ul class="footer__links">
        {
          info.map((link) => (
            <li>
              <a href={url(link.href)} class="footer__link">
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </div>

  <div class="footer__bottom">
    <div class="container footer__bottom-inner">
      <span class="footer__copy">
        &copy; {new Date().getFullYear()} TT Motorcycle School. All rights reserved.
      </span>
      <ul class="footer__legal">
        {
          legal.map((link) => (
            <li>
              <a href={url(link.href)} class="footer__legal-link">
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</footer>

<style>
  .footer {
    background-color: var(--color-primary);
    color: #ccc;
    padding-top: var(--space-16);
  }

  .footer__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-10);
  }

  @media (min-width: 640px) {
    .footer__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 900px) {
    .footer__grid {
      grid-template-columns: 2fr 1fr 1fr;
    }
  }

  .footer__brand img {
    margin-bottom: var(--space-4);
  }

  .footer__tagline {
    font-size: var(--text-sm);
    line-height: var(--leading-normal);
    margin-bottom: var(--space-5);
    color: #aaa;
    max-width: 320px;
  }

  .footer__cta {
    display: inline-block;
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--color-accent);
    transition: color var(--transition);
  }

  .footer__cta:hover {
    color: #fff;
  }

  .footer__col-title {
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-white);
    margin-bottom: var(--space-4);
  }

  .footer__links {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .footer__link {
    font-size: var(--text-sm);
    color: #aaa;
    transition: color var(--transition);
  }

  .footer__link:hover {
    color: var(--color-white);
  }

  .footer__bottom {
    margin-top: var(--space-12);
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    padding-block: var(--space-5);
  }

  .footer__bottom-inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
  }

  .footer__copy {
    font-size: var(--text-xs);
    color: #666;
  }

  .footer__legal {
    display: flex;
    gap: var(--space-4);
  }

  .footer__legal-link {
    font-size: var(--text-xs);
    color: #666;
    transition: color var(--transition);
  }

  .footer__legal-link:hover {
    color: var(--color-white);
  }
</style>
