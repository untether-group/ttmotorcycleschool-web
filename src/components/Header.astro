---
const navLinks = [
  { label: "Home", href: "/" },
  { label: "New Rider", href: "/new-rider/" },
  { label: "CBT", href: "/cbt/" },
  { label: "Full Licence", href: "/full-licence/" },
  { label: "Prices", href: "/prices/" },
  { label: "About", href: "/about/" },
  { label: "Contact", href: "/contact/" },
];

const currentPath = Astro.url.pathname;
---

<header class="header">
  <div class="container header__inner">
    <!-- Logo -->
    <a href="/" class="header__logo" aria-label="TT Motorcycle School — Home">
      <img src="/logo.svg" alt="TT Motorcycle School" width="160" height="48" />
    </a>

    <!-- Desktop nav -->
    <nav class="header__nav" aria-label="Primary navigation">
      <ul class="header__nav-list">
        {
          navLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class:list={[
                  "header__nav-link",
                  { "header__nav-link--active": currentPath === link.href },
                ]}
                aria-current={currentPath === link.href ? "page" : undefined}
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <!-- CTA -->
    <a href="/cbtbooking/" class="header__cta btn btn--accent">Book Now</a>

    <!-- Mobile hamburger -->
    <button
      class="header__hamburger"
      aria-label="Open navigation menu"
      aria-expanded="false"
      aria-controls="mobile-nav"
      id="hamburger-btn"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="#ffffff"
        stroke-width="2.5"
        stroke-linecap="round"
        aria-hidden="true"
      >
        <line x1="3" y1="6" x2="21" y2="6"></line>
        <line x1="3" y1="12" x2="21" y2="12"></line>
        <line x1="3" y1="18" x2="21" y2="18"></line>
      </svg>
    </button>
  </div>

  <!-- Mobile nav drawer -->
  <div class="header__mobile-nav" id="mobile-nav" aria-hidden="true">
    <nav aria-label="Mobile navigation">
      <ul class="header__mobile-list">
        {
          navLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class:list={[
                  "header__mobile-link",
                  { "header__mobile-link--active": currentPath === link.href },
                ]}
              >
                {link.label}
              </a>
            </li>
          ))
        }
        <li>
          <a
            href="/cbtbooking/"
            class="btn btn--accent"
            style="display:block;text-align:center;margin-top:1rem;"
          >
            Book Now
          </a>
        </li>
      </ul>
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById("hamburger-btn");
  const nav = document.getElementById("mobile-nav");

  btn?.addEventListener("click", () => {
    const isOpen = btn.getAttribute("aria-expanded") === "true";
    btn.setAttribute("aria-expanded", String(!isOpen));
    nav?.setAttribute("aria-hidden", String(isOpen));
    btn.classList.toggle("is-open", !isOpen);
    nav?.classList.toggle("is-open", !isOpen);
  });

  // Close on nav link click (mobile)
  nav?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => {
      btn?.setAttribute("aria-expanded", "false");
      nav.setAttribute("aria-hidden", "true");
      btn?.classList.remove("is-open");
      nav.classList.remove("is-open");
    });
  });
</script>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 100;
    background-color: var(--color-primary);
    border-bottom: 2px solid var(--color-accent);
  }

  .header__inner {
    display: flex;
    align-items: center;
    gap: var(--space-6);
    height: 68px;
  }

  .header__logo img {
    height: 42px;
    width: auto;
  }

  /* Desktop nav */
  .header__nav {
    display: none;
    margin-left: auto;
  }

  @media (min-width: 900px) {
    .header__nav {
      display: block;
    }
    .header__cta {
      display: inline-flex;
    }
    .header__hamburger {
      display: none;
    }
  }

  .header__nav-list {
    display: flex;
    gap: var(--space-1);
    align-items: center;
  }

  .header__nav-link {
    display: block;
    padding: var(--space-2) var(--space-3);
    font-size: var(--text-sm);
    font-weight: 600;
    color: #ccc;
    border-radius: var(--radius-sm);
    transition:
      color var(--transition),
      background var(--transition);
    white-space: nowrap;
  }

  .header__nav-link:hover,
  .header__nav-link--active {
    color: var(--color-white);
    background-color: rgba(255, 255, 255, 0.08);
  }

  /* CTA button */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: 700;
    line-height: 1;
    padding: 0.625rem 1.25rem;
    border-radius: var(--radius-sm);
    border: 2px solid transparent;
    cursor: pointer;
    transition:
      background-color var(--transition),
      color var(--transition),
      border-color var(--transition);
    white-space: nowrap;
    text-decoration: none;
  }

  .btn--accent {
    background-color: var(--color-accent);
    color: var(--color-white);
    border-color: var(--color-accent);
  }

  .btn--accent:hover {
    background-color: var(--color-accent-hover);
    border-color: var(--color-accent-hover);
  }

  .header__cta {
    margin-left: auto;
    display: none;
  }

  @media (min-width: 900px) {
    .header__cta {
      display: inline-flex;
      margin-left: var(--space-4);
    }
  }

  /* Hamburger */
  .header__hamburger {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 6px;
    width: 36px;
    height: 36px;
    background: transparent;
    border: none;
    outline: none;
    cursor: pointer;
    margin-left: auto;
    padding: 4px;
    z-index: 120;
  }

  .header__hamburger svg {
    display: block;
    transition: opacity 0.2s ease;
  }

  .header__hamburger.is-open svg {
    opacity: 0.7;
  }

  /* Mobile nav drawer */
  .header__mobile-nav {
    display: none;
    background-color: var(--color-primary-soft);
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .header__mobile-nav.is-open {
    display: block;
  }

  @media (min-width: 900px) {
    .header__mobile-nav {
      display: none !important;
    }
    .header__hamburger {
      display: none;
    }
  }

  .header__mobile-list {
    padding: var(--space-4) var(--container-px) var(--space-6);
  }

  .header__mobile-link {
    display: block;
    padding: var(--space-3) 0;
    font-size: var(--text-base);
    font-weight: 600;
    color: #ccc;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    transition: color var(--transition);
  }

  .header__mobile-link:hover,
  .header__mobile-link--active {
    color: var(--color-white);
  }
</style>
